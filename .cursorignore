# Cursor ignore rules (affects AI indexing/reading & file tree).
# Mirror `.gitignore`, but make everything visible to Cursor/AI:
# - Lines that already start with `!` are kept as-is
# - Other non-empty, non-comment lines are prefixed with `!`

!__pycache__/
!*.py[cod]
!*.pyo
!*.pyd
!*.egg-info/
!.eggs/
!build/
!dist/
!.mypy_cache/
!.pytest_cache/
!.ruff_cache/
!*.log
!.coverage
!coverage.xml

!.venv/
!venv/
!env/
!.env
!.env.*/

!.idea/
!.vscode/
!.cursor/

!Thumbs.db
!.DS_Store

!*.ipynb

!.tmp_*.py

!runtime/cache/
!app/runtime/cache/
!app/runtime/todo_states/
!user_settings.json

!engine/app/runtime/cache/

!runtime/graph_cache/
!runtime/resource_cache/
!runtime/node_cache/
!runtime/name_sync_state.json

!docs/**
!projects/

!docs/
!docs/README.md
!docs/用户必读.md
!docs/claude.md

!assets/资源库/**

!assets/资源库/
!assets/资源库/**/

!assets/资源库/**/示例_*
!assets/资源库/**/模板示例_*

!assets/资源库/**/节点图/校验节点图.py
