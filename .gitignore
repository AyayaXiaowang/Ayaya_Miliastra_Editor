runtime/graph_cache/
runtime/resource_cache/
runtime/node_cache/
runtime/name_sync_state.json

# 打包与分发脚本（版本化；产物仍写入 release/ 并保持忽略）

# ---------- 资源库（版本化） ----------
# `assets/资源库/` 需要被程序员开发与协作：不做默认忽略。
# 编译产物与缓存仍应忽略（已由全局规则覆盖：__pycache__/ *.pyc 等）。

# UI Workbench bundle 输出（构建产物；写回端会读取，但应由 HTML 重新生成，避免把旧产物提交进仓库）
assets/资源库/项目存档/**/管理配置/UI源码/__workbench_out__/*.ui_bundle.json



# 项目存档归档快照（原始解析/二进制数据块/大体量 dump；默认不对外）
assets/资源库/项目存档/_archive/**

# 对外开源发布：内容/授权未确认前，默认不上传（Need Confirm）

assets/资源库/项目存档/锻刀/**
assets/资源库/项目存档/第七关/**
# 项目存档下的临时/对比/验证包：一律视为临时产物，不入库
assets/资源库/项目存档/__tmp_*/
assets/资源库/项目存档/_tmp_*/
assets/资源库/项目存档/verify_*/
assets/资源库/项目存档/cmp_*/
assets/资源库/项目存档/临时诊断_*/
projects/**
# Release artifacts (local build outputs)
release/**
!release/claude.md

# Local scratch / generated artifacts (not versioned)
tmp/**
# tmp_ 开头的临时目录（如 tmp_user_case_compare/ 等调试对比目录）
tmp_*/

# 构建/导出输出目录（性质同 release/，不进仓库）
out/

# Private extensions artifacts (generated / debug outputs)
private_extensions/**/_artifacts/_debug_screenshots/**

# Private extensions export outputs（导出/对比/诊断产物；禁止上传）
private_extensions/**/out/**

# Nested git repositories inside private_extensions（严禁上传；同时避免误 add）
private_extensions/**/.git/**

# Private extensions caches（生成缓存；禁止上传）
private_extensions/**/*.cache.json

# ugc_file_tools 本地样本与解析状态（可再生成/可能包含本机或未授权内容；默认不对外）
private_extensions/ugc_file_tools/save/**

# ugc_file_tools 内置资源（运行必需/默认依赖的 seed；需要随仓库分发）
# - 该目录为“对外仓库可版本化的最小 seed”
# - 其余真源/样本请放在 save/ 并默认忽略
!private_extensions/ugc_file_tools/builtin_resources/**
!private_extensions/ugc_file_tools/builtin_resources/claude.md
# 对外开源发布：`builtin_resources/资产/` 目录不随仓库上传（已迁移到 builtin_resources/gia_templates/）
private_extensions/ugc_file_tools/builtin_resources/资产/**
private_extensions/ugc_file_tools/parse_status/**
!private_extensions/ugc_file_tools/parse_status/claude.md

# UI schema library 沉淀数据（由 recorder 自动生成；可能包含私有 UI 信息与本机绝对路径）
private_extensions/ugc_file_tools/ui_schema_library/data/index.json
private_extensions/ugc_file_tools/ui_schema_library/data/records/**

# ugc_file_tools 旧版 GIA 模板目录（已迁移到 builtin_resources/资产/；旧路径避免误入库）
private_extensions/ugc_file_tools/资产/**

