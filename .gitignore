__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/
build/
dist/
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.log
.coverage
coverage.xml

# Virtual env
.venv/
venv/
env/
.env
.env.*/

# IDE / Editors
.idea/
.vscode/
.cursor/

# OS artifacts
Thumbs.db
.DS_Store

# Jupyter notebooks（只在本地使用，不进仓库）
*.ipynb

# Local scratch / temporary debug scripts
.tmp_*.py

# Project caches and local state
runtime/cache/
app/runtime/cache/
app/runtime/todo_states/
user_settings.json

# 防止误把 workspace_path 指到 engine/ 导致缓存跑到 engine/app/runtime/cache
engine/app/runtime/cache/

# Directory rules docs:
# - Public directories: `claude.md` is versioned to document purpose/state/notes.
# - Private directories: rely on the directory-level ignore rules below (docs/**, projects/, assets/资源库/** ...).

# 旧版 runtime 缓存路径（兼容历史）
runtime/graph_cache/
runtime/resource_cache/
runtime/node_cache/
runtime/name_sync_state.json

# 本地私有工程目录（不随仓库分发）
docs/**
projects/

# 公开用户文档（从 docs/ 目录中精确放行）
!docs/
!docs/README.md
!docs/用户必读.md
!docs/claude.md

# 打包与分发脚本（版本化；产物仍写入 release/ 并保持忽略）

# ---------- 资源库上传策略 ----------
# 默认忽略整个资源库内容
assets/资源库/**

# 但保留资源库及其子目录结构本身，便于后续精细控制
!assets/资源库/
!assets/资源库/**/

# 允许：以“示例_”或“模板示例_”开头的资源文件（任意子目录、任意后缀）
!assets/资源库/**/示例_*
!assets/资源库/**/模板示例_*

# 节点图校验脚本 / 目录规则文档（精确白名单，避免扩大资源库入库范围）
# - 节点图脚本已迁移为“workspace bootstrap + app.runtime.engine.graph_prelude_*”，不再依赖资源库内的 `_prelude.py/.pyi`
# - 如需在某个节点图根目录放置 `校验节点图.py` 作为快捷入口，可放行该文件
!assets/资源库/**/节点图/校验节点图.py
!assets/资源库/共享/节点图/**/claude.md

# ---------- 项目存档上传策略 ----------
# 项目存档通常包含本地工作内容，默认不入库；仅版本化“示例项目模板”作为公开模板/回归基线。
assets/资源库/项目存档/**
!assets/资源库/项目存档/
!assets/资源库/项目存档/示例项目模板/
!assets/资源库/项目存档/示例项目模板/**/
!assets/资源库/项目存档/示例项目模板/**

# 但即使被白名单放行，也必须继续忽略编译产物与缓存目录/文件（否则会把 .pyc 等带进仓库）
assets/资源库/**/__pycache__/
assets/资源库/**/*.py[cod]
assets/资源库/**/*.pyo
assets/资源库/**/*.pyd

# 明确白名单：官方内置"信号/结构体全类型示例"
!assets/资源库/共享/管理配置/结构体定义/基础结构体/全类型结构体示例.py
!assets/资源库/共享/管理配置/信号/signal_all_supported_types_example.py

# 明确白名单：模板示例节点图依赖的教学示例信号（用于 CI 回归）
!assets/资源库/共享/管理配置/信号/signal_example_pedal_switch_state.py
!assets/资源库/共享/管理配置/信号/signal_example_pedal_switch_activation_ack.py

# 如需额外的测试资源，可以在此处增加精确白名单，例如：
# !assets/资源库/实例/测试_关卡1.json
# !assets/资源库/实例/测试用/**

# Release artifacts (local build outputs)
release/**
!release/claude.md

# Local scratch / generated artifacts (not versioned)
tmp/**

# Internal dev tools (not shipped / not versioned)
tools/**




# # Local private extensions (not shipped / not versioned)
# private_extensions/**

# # ---------- plugins 目录的版本化策略 ----------
# # 目标：
# # - `plugins/nodes/**` 作为公共“节点实现”是版本化内容；
# # - `plugins/` 下的其它扩展（例如本地私有 UI 扩展）默认不入库，避免误提交。
# plugins/**
# !plugins/
# !plugins/__init__.py
# !plugins/claude.md
# !plugins/nodes/
# !plugins/nodes/**

# # 但 `plugins/nodes/**` 被白名单放行后，仍必须继续忽略 Python 编译缓存
# plugins/nodes/**/__pycache__/
# plugins/nodes/**/*.py[cod]
# plugins/nodes/**/*.pyo
# plugins/nodes/**/*.pyd

